# PostgreSQL local
DB_URL=jdbc:postgresql://localhost:5433/handbagdb
DB_USERNAME=postgres
DB_PASSWORD=postgres
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
POSTGRES_DB=handbagdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# App security/config
JWT_SECRET=change-me-to-a-long-random-secret
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,https://crystal-handbags.vercel.app
APP_FRONTEND_URL=https://crystal-handbags.vercel.app

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# VNPAY
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=http://localhost:8080/api/payments/vnpay/return
VNPAY_IPN_URL=http://localhost:8080/api/payments/vnpay/ipn

# AI
OPENROUTER_API_KEY=

# Gmail SMTP
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-southeast-1
